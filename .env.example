# ---------------------------------------------------------------------------
# Tracklock environment variables
# Copy this file to .env.local and fill in your own values.
# ---------------------------------------------------------------------------

# Supabase project URL and anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER ONLY. Never expose to the browser.
# Used for privileged operations: locking agreements, admin reads, audit writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the app (used to build invite/signing links + auth redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend transactional email. If unset, emails are logged to the server console
# instead of being sent (useful for local/private-beta development).
RESEND_API_KEY=
EMAIL_FROM="Tracklock <splits@tracklock.app>"

# Comma-separated list of admin email addresses with access to /admin.
TRACKLOCK_ADMIN_EMAILS=
